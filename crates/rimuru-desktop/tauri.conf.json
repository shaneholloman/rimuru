{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/v2/crates/tauri-config-schema/schema.json",
  "productName": "Rimuru",
  "identifier": "com.rimuru.desktop",
  "build": {
    "devUrl": "http://localhost:3100",
    "frontendDist": "../../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Rimuru",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "url": "http://localhost:3100"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "tooltip": "Rimuru",
      "iconPath": "icons/icon.png"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
